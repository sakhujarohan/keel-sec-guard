  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@google/generative-ai": "^0.24.1",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "license": "MIT"
}
