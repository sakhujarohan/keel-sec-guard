{
  "name": "keel-sec-guard",
  "version": "1.0.0",
  "description": "Hybrid SAST + Gemini LLM Security Reviewer for Agent & Developer PRs",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "keel-sec-guard": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "check": "biome check . && tsc --noEmit && vitest run",
